{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0.2,
    "languages": ["zh"],
    "azure_endpoint_env": null,
    "api_version": null
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 50,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Federal Reserve Press Releases",
        "url": "https://www.federalreserve.gov/feeds/press_all.xml",
        "enabled": true,
        "category": "macro"
      },
      {
        "name": "FOMC",
        "url": "https://www.federalreserve.gov/feeds/press_monetary.xml",
        "enabled": true,
        "category": "macro"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 0
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": null
  },
  "filtering": {
    "ai_score_threshold": 3.0,
    "time_window_hours": 24
  },
  "email": null,
  "webhook": null
}
